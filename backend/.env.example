# ── Application ──────────────────────────────────
NODE_ENV=development
PORT=5000
API_VERSION=v1

# ── MongoDB ──────────────────────────────────────
MONGODB_URI=mongodb://localhost:27017/mediread_dev
MONGODB_DB_NAME=mediread_dev

# ── CORS ─────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# ── Rate Limiting ─────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# ── File Upload ───────────────────────────────────
MAX_FILE_SIZE_MB=10
UPLOAD_DIR=uploads

# ── Logging ───────────────────────────────────────
LOG_LEVEL=debug
LOG_DIR=logs

# ── Gemini Vision AI ───────────────────────────────
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-1.5-flash
GEMINI_TIMEOUT_MS=30000
GEMINI_MAX_RETRIES=3

# ── Authentication ─────────────────────────────────
JWT_ACCESS_SECRET=replace_with_a_long_random_string_min_32_chars
JWT_REFRESH_SECRET=replace_with_a_different_long_random_string
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
BCRYPT_SALT_ROUNDS=12